function describeFruitBasket() {
  let fruitBasket = [
    "Apple",
    "Banana",
    "Orange",
    "Mango",
    "Grapes",
    "Pineapple"
  ];

  let numberOfFruits = fruitBasket.length;

  if (numberOfFruits <= 3) {
    return "We have a small fruit basket with " + numberOfFruits + " fruits!";
  } else {
    return "We have a big fruit basket with " + numberOfFruits + " fruits!";
  }
}

// Testing
console.log(describeFruitBasket());