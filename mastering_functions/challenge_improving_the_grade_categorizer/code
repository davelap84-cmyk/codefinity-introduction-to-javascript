// Convert the code below into a function
function getGrade(grade) {

if (grade >= 90) {
  return("Grade: A");
} else if (grade >= 80) {
  return("Grade: B");
} else if (grade >= 70) {
  return("Grade: C");
} else if (grade >= 60) {
  return("Grade: D");
} else {
  return("Grade: F");
}
}
// Testing
console.log(getGrade(30));
console.log(getGrade(50));
console.log(getGrade(70));
console.log(getGrade(97));
